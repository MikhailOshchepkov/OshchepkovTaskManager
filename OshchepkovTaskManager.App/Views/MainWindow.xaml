<Window x:Class="OshchepkovTaskManager.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OshchepkovTaskManager.App.ViewModels"
        xmlns:conv="clr-namespace:OshchepkovTaskManager.App.Converters"
        Title="OshchepkovTaskManager"
        Width="1160" Height="720"
        MinWidth="860" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1F">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:ImportanceConverter       x:Key="ImportConv"/>
        <conv:ImportanceColorConverter  x:Key="ImportColorConv"/>
        <conv:StatusDisplayConverter    x:Key="StatusConv"/>
        <conv:PriorityDisplayConverter  x:Key="PriorityConv"/>
        <conv:PriorityColorConverter    x:Key="PriorityColorConv"/>
        <conv:NullToVisibilityConverter x:Key="NullVisConv"/>
        <conv:StatusBadgeColorConverter x:Key="StatusBadgeConv"/>
    </Window.Resources>

    <DockPanel>

        <!-- Боковая панель -->
        <Border DockPanel.Dock="Left"
                Width="220"
                Background="#222228"
                BorderBrush="#33333E"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Логотип -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                    <StackPanel>
                        <TextBlock Text="TASK"
                                   FontSize="22" FontWeight="Black"
                                   Foreground="#7C6AF7"/>
                        <TextBlock Text="MANAGER"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#606078"
                                   Margin="0,-2,0,0"/>
                        <TextBlock Text="Ощепков"
                                   FontSize="11"
                                   Foreground="#606078"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top" Height="1" Background="#33333E" Margin="20,0"/>

                <!-- Кнопки действий -->
                <StackPanel DockPanel.Dock="Top" Margin="12,20,12,0">
                    <Button Content="+ Добавить задачу"
                            Command="{Binding AddTaskCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Padding="0,11"
                            Margin="0,0,0,8"/>
                    <Button Content="Редактировать"
                            Command="{Binding EditTaskCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Padding="0,9"
                            Margin="0,0,0,6"/>
                    <Button Content="Удалить"
                            Command="{Binding DeleteTaskCommand}"
                            Style="{StaticResource DangerButton}"
                            HorizontalAlignment="Stretch"
                            Padding="0,9"
                            Margin="0,0,0,20"/>

                    <Border Height="1" Background="#33333E" Margin="0,0,0,20"/>

                    <Button Content="Сохранить в файл"
                            Command="{Binding SaveFileCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Padding="0,9"
                            Margin="0,0,0,6"/>
                    <Button Content="Открыть файл"
                            Command="{Binding LoadFileCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Padding="0,9"/>
                </StackPanel>

                <!-- Статистика -->
                <Border DockPanel.Dock="Bottom"
                        Background="#1A1A1F"
                        BorderBrush="#33333E"
                        BorderThickness="0,1,0,0"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="СТАТИСТИКА"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#606078"
                                   Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Всего" Foreground="#9090A8" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatTotal}"
                                       Foreground="#EEEEF5" FontWeight="Bold" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Новых" Foreground="#9090A8" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatNew}"
                                       Foreground="#7C6AF7" FontWeight="Bold" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="В процессе" Foreground="#9090A8" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatInProgress}"
                                       Foreground="#E0A040" FontWeight="Bold" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Завершено" Foreground="#9090A8" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatCompleted}"
                                       Foreground="#4CAF80" FontWeight="Bold" FontSize="13"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Просрочено" Foreground="#9090A8" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatOverdue}"
                                       Foreground="#E05C5C" FontWeight="Bold" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- Основная область -->
        <DockPanel Background="#1A1A1F">

            <!-- Статус-бар -->
            <Border DockPanel.Dock="Bottom"
                    Background="#222228"
                    BorderBrush="#33333E"
                    BorderThickness="0,1,0,0"
                    Padding="20,6">
                <TextBlock Text="{Binding StatusBarText}"
                           Foreground="#606078"
                           FontSize="11"/>
            </Border>

            <!-- Панель поиска и фильтров -->
            <Border DockPanel.Dock="Top"
                    Background="#222228"
                    BorderBrush="#33333E"
                    BorderThickness="0,0,0,1"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Поле поиска -->
                    <Grid Grid.Column="0" Margin="0,0,16,0">
                        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="36"/>
                        <TextBlock IsHitTestVisible="False"
                                   Text="Поиск по названию или описанию..."
                                   Foreground="#606078"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Фильтр статуса -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="Статус" Foreground="#606078" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding FilterOptions}"
                                  SelectedItem="{Binding FilterStatus}"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="130" Height="36"/>
                    </StackPanel>

                    <!-- Сортировка -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="Сортировка" Foreground="#606078" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SortMode}"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="155" Height="36"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Content="Сбросить"
                            Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Height="36"
                            FontSize="12"/>
                </Grid>
            </Border>

            <!-- Заголовки таблицы -->
            <Border DockPanel.Dock="Top"
                    Background="#222228"
                    BorderBrush="#33333E"
                    BorderThickness="0,0,0,1"
                    Padding="20,0">
                <Grid Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="★"        Foreground="#606078" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="НАЗВАНИЕ" Foreground="#606078" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="ОПИСАНИЕ" Foreground="#606078" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="ПРИОРИТЕТ" Foreground="#606078" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="СТАТУС"    Foreground="#606078" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="СРОК"      Foreground="#606078" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="СОЗДАНО"   Foreground="#606078" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Список задач -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#1A1A1F">
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="RowBorder"
                                    Background="#222228"
                                    BorderBrush="#33333E"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,0"
                                    Height="52"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectTaskCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.EditTaskCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                </Border.InputBindings>
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Звёздочка важности -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding IsImportant, Converter={StaticResource ImportConv}}"
                                               Foreground="{Binding IsImportant, Converter={StaticResource ImportColorConv}}"
                                               FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               Foreground="#EEEEF5"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Description}"
                                               Foreground="#9090A8"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Border Grid.Column="3"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="5"
                                            Padding="10,4"
                                            Background="{Binding Priority, Converter={StaticResource PriorityColorConv}}">
                                        <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityConv}}"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   FontWeight="Bold"/>
                                    </Border>

                                    <Border Grid.Column="4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="5"
                                            Padding="10,4"
                                            Background="{Binding Status, Converter={StaticResource StatusBadgeConv}}">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusConv}}"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   FontWeight="Bold"/>
                                    </Border>

                                    <TextBlock Grid.Column="5"
                                               Text="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                               Foreground="#9090A8"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="6"
                                               Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                               Foreground="#606078"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                    <Setter TargetName="RowBorder" Property="BorderBrush" Value="#4A2525"/>
                                    <Setter TargetName="RowBorder" Property="Background" Value="#2A1F1F"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </DockPanel>
</Window>
